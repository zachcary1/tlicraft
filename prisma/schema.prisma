generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GearType {
  CRAFTED
  VORAX
  LEGENDARY
}

enum AttributeType {
  STR
  DEX
  INT
}

enum AffixGroupType {
  BASE_AFFIXES
  CORROSION_BASE_AFFIXES
  SWEET_DREAM_AFFIXES
  NIGHTMARE_AFFIXES
  INTERMEDIATE_SEQUENCES
  ADVANCED_SEQUENCES
  BASIC_PREFIXES
  ADVANCED_PREFIXES
  ULTIMATE_PREFIXES
  BASIC_SUFFIXES
  ADVANCED_SUFFIXES
  ULTIMATE_SUFFIXES
}

enum TierName {
  T0_PLUS
  T0
  T1
  T2
  T3
  T4
  T5
  T6
  T7
}

enum StatUnit {
  PERCENT
  FLAT
  NONE
}

model BaseItemCategory {
  id    String @id
  name  String

  craftedPools CraftedItemPool[]
  weaponTypes  WeaponType[]
}

model WeaponType {
  id                 String @id
  name               String
  baseItemCategoryId String
  baseItemCategory   BaseItemCategory @relation(fields: [baseItemCategoryId], references: [id])

  craftedPools CraftedItemPool[]
}

model CraftedItemPool {
  id                 String @id
  name               String
  gearType           GearType @default(CRAFTED)

  baseItemCategoryId String
  baseItemCategory   BaseItemCategory @relation(fields: [baseItemCategoryId], references: [id])

  weaponTypeId       String?
  weaponType         WeaponType? @relation(fields: [weaponTypeId], references: [id])

  attributeType      AttributeType?
  isPriceless        Boolean @default(false)

  affixGroups        CraftedAffixGroup[]

  @@index([baseItemCategoryId])
  @@index([weaponTypeId])
  @@index([attributeType])
  @@index([isPriceless])
}

model CraftedAffixGroup {
  id         String @id
  poolId     String
  groupType  AffixGroupType

  pool       CraftedItemPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  affixes    CraftedAffix[]

  @@unique([poolId, groupType])
  @@index([poolId])
}

model CraftedAffix {
  id        String @id
  groupId   String
  name      String

  group      CraftedAffixGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tiers      CraftedAffixTier[]

  @@index([groupId])
}

model CraftedAffixTier {
  id           String @id
  affixId      String
  tier         TierName

  affix        CraftedAffix @relation(fields: [affixId], references: [id], onDelete: Cascade)
  stats        CraftedAffixTierStat[]

  @@unique([affixId, tier])
  @@index([affixId])
}

model CraftedAffixTierStat {
  id        String @id
  tierId    String
  statId    String
  label     String
  minValue  Float
  maxValue  Float
  unit      StatUnit

  tier      CraftedAffixTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@index([tierId])
  @@index([statId])
}

model Skill {
  id     String   @id
  name   String
  type   String
  tags   String[]
  effect String

  @@index([type])
}

model Blend {
  id     String @id
  type   String
  name   String
  effect String

  @@index([type])
}

model Destiny {
  id     String @id
  type   String
  name   String
  effect String

  @@index([type])
}

model EtherealPrism {
  id     String @id
  type   String
  rarity String
  effect String

  @@index([type])
}

model GearAffix {
  id        String @id
  category  String
  item      String
  itemGroup String
  type      String
  pool      String
  tier      String
  effect    String

  @@index([category])
  @@index([item])
  @@index([type])
}

model HeroMemory {
  id     String @id
  type   String
  item   String
  effect String
  tier   String @default("")

  @@index([type])
  @@index([item])
}

model HeroTrait {
  id        String @id
  heroGroup String
  hero      String
  name      String
  level     Int
  effect    String

  @@index([heroGroup])
  @@index([hero])
}

model Legendary {
  id       String @id
  category String
  item     String
  name     String
  affixes  String

  @@index([category])
  @@index([item])
}

model PactSpirit {
  id     String   @id
  type   String
  rarity String
  name   String
  tags   String[]
  effect String

  @@index([type])
  @@index([rarity])
}

model Talent {
  id     String @id
  god    String
  tree   String
  type   String
  name   String
  effect String

  @@index([god])
  @@index([tree])
  @@index([type])
}

model MemoryRevival {
  id     String @id
  type   String
  name   String
  hero   String
  effect String

  @@index([type])
}

model RenewedMemory {
  id     String @id
  type   String
  name   String
  hero   String
  effect String

  @@index([type])
}